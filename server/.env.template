# ============================================
#  Animate CC 后端环境变量配置
# ============================================
# 复制此文件为 .env 并填入实际值
# cp .env.template .env

# 服务端口
PORT=8000

# 数据库连接（默认 SQLite，可选 PostgreSQL）
DATABASE_URL=sqlite+aiosqlite:///./animate_cc.db

# 如需使用 PostgreSQL，取消注释以下配置：
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/animate_cc
