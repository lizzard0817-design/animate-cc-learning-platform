[Unit]
Description=Animate CC Learning Platform API
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/opt/animate-cc-api/server
Environment="PATH=/opt/animate-cc-api/server/venv/bin:/usr/bin"
ExecStart=/opt/animate-cc-api/server/venv/bin/uvicorn main:app --host 0.0.0.0 --port 8000
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
